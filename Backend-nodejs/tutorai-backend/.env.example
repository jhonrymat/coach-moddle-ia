# ─────────────────────────────────────────────────────────────────
# TutorAI Backend — Variables de entorno
# Copia este archivo como .env para desarrollo local
# En Hostinger: configura estas variables en hPanel → Node.js App → Environment Variables
# NUNCA subas el .env real al servidor ni a GitHub
# ─────────────────────────────────────────────────────────────────

# Puerto del servidor (Hostinger lo asigna automáticamente — no cambiar en producción)
PORT=3000

# URL completa de tu Moodle (sin barra final)
MOODLE_URL=https://campusvirtual.edu.co

# Secret compartido con el plugin PHP de Moodle
# Genera uno seguro con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_SECRET=cambia_esto_por_un_secret_seguro_de_64_caracteres

# Clave API de OpenAI
OPENAI_API_KEY=sk-...

# Modelo a usar (gpt-4o-mini es más barato, gpt-4o es más potente)
OPENAI_MODEL=gpt-4o-mini

# Máximo de mensajes de historial a recordar por sesión
MAX_HISTORY=20

# Ruta de la base de datos SQLite (Hostinger la crea automáticamente)
DB_PATH=./data/tutorai.db
